---
/**
 * ContactForm.astro
 * ------------------------------------------------------------------
 * Minimalist form — no solid input boxes; only thin bottom borders with
 * floating labels. Features a magnetic primary submit button and a
 * direct WhatsApp CTA. All contact values come from siteConfig.
 *
 * Floating labels use logical (start-anchored) positioning so they work
 * in both LTR (English) and RTL (Arabic) without restyling.
 *
 * Submission is intercepted client-side to keep the build 100% static
 * (no backend). Swap `handleSubmit` for a real fetch call when wired up.
 */
import { siteConfig } from '../data/siteConfig';
import { t, isRTL } from '../i18n';

const c = siteConfig.contact;
const cs = siteConfig.contactSection;
const forwardArrow = isRTL ? '←' : '→';
const whatsappHref = `https://wa.me/${c.whatsapp.replace(/[^0-9]/g, '')}?text=${encodeURIComponent(
  isRTL
    ? 'مرحباً نَسيم، أود الاستفسار حول مشاريعكم.'
    : 'Hello Naseem, I’d like to enquire about your projects.',
)}`;

const fields = [
  { name: 'name', label: t(cs.fields.name), type: 'text' as const, autocomplete: 'name' },
  { name: 'phone', label: t(cs.fields.phone), type: 'tel' as const, autocomplete: 'tel' },
  { name: 'email', label: t(cs.fields.email), type: 'email' as const, autocomplete: 'email' },
];
---

<section id="contact" class="relative bg-brand-surface py-24 sm:py-32 px-6 sm:px-8 lg:px-14">
  <div class="max-w-screen-xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
    <!-- ============================================================
         LEFT — invitation + direct channels
         ============================================================ -->
    <div>
      <div class="mb-10 flex items-center gap-4">
        <span class="h-px w-12 bg-brand-accent"></span>
        <p class="font-body text-xs tracking-[0.3em] text-brand-accent uppercase">{t(cs.eyebrow)}</p>
      </div>

      <h2 class="font-heading text-3xl sm:text-4xl lg:text-5xl text-brand-text max-w-md leading-snug">
        {t(cs.heading)}
      </h2>
      <p class="mt-6 font-body text-base text-brand-muted max-w-md leading-relaxed">
        {t(cs.body)}
      </p>

      <div class="mt-10 space-y-5 font-body">
        <a
          href={`tel:${c.phone}`}
          class="interactive-card flex items-center gap-4 group"
          data-magnetic
        >
          <span class="grid h-10 w-10 place-items-center rounded-full border border-brand-accent/30 text-brand-accent text-sm group-hover:bg-brand-accent group-hover:text-brand-bg transition-colors duration-300">☎</span>
          <span class="flex flex-col">
            <span class="text-xs text-brand-muted">{t(cs.callLabel)}</span>
            <span class="text-lg text-brand-text" dir="ltr">{c.phoneDisplay}</span>
          </span>
        </a>

        <a
          href={whatsappHref}
          target="_blank"
          rel="noopener noreferrer"
          class="interactive-card flex items-center gap-4 group"
          data-magnetic
        >
          <span class="grid h-10 w-10 place-items-center rounded-full border border-brand-accent/30 text-brand-accent text-sm group-hover:bg-brand-accent group-hover:text-brand-bg transition-colors duration-300">✦</span>
          <span class="flex flex-col">
            <span class="text-xs text-brand-muted">{t(cs.whatsappLabel)}</span>
            <span class="text-lg text-brand-text">{t(c.whatsappDisplay)}</span>
          </span>
        </a>

        <a
          href={`mailto:${c.email}`}
          class="interactive-card flex items-center gap-4 group"
          data-magnetic
        >
          <span class="grid h-10 w-10 place-items-center rounded-full border border-brand-accent/30 text-brand-accent text-sm group-hover:bg-brand-accent group-hover:text-brand-bg transition-colors duration-300">✉</span>
          <span class="flex flex-col">
            <span class="text-xs text-brand-muted">{t(cs.emailLabel)}</span>
            <span class="text-lg text-brand-text" dir="ltr">{c.email}</span>
          </span>
        </a>

        <p class="pt-4 text-sm text-brand-muted">{t(c.address)}</p>
      </div>
    </div>

    <!-- ============================================================
         RIGHT — floating-label form
         Labels are anchored to the inline-start edge (logical), so they
         sit on the left for English and the right for Arabic automatically.
         ============================================================ -->
    <form
      data-contact-form
      class="w-full"
      autocomplete="on"
    >
      <div class="space-y-10">
        {fields.map((field) => (
          <div class="relative" data-float-field>
            <input
              id={`field-${field.name}`}
              name={field.name}
              type={field.type}
              autocomplete={field.autocomplete}
              placeholder=" "
              required
              class="peer w-full bg-transparent border-b border-brand-accent/30 py-3 text-brand-text font-body text-base outline-none transition-colors duration-300 focus:border-brand-accent placeholder-transparent text-start"
            />
            <label
              for={`field-${field.name}`}
              class="pointer-events-none absolute inset-inline-start-0 top-3 font-body text-base text-brand-muted transition-all duration-300 start-3
                peer-focus:-top-4 peer-focus:text-xs peer-focus:text-brand-accent
                peer-[:not(:placeholder-shown)]:-top-4 peer-[:not(:placeholder-shown)]:text-xs"
            >
              {field.label}
            </label>
          </div>
        ))}

        <div class="relative" data-float-field>
          <textarea
            id="field-message"
            name="message"
            rows="4"
            placeholder=" "
            class="peer w-full resize-none bg-transparent border-b border-brand-accent/30 py-3 text-brand-text font-body text-base outline-none transition-colors duration-300 focus:border-brand-accent placeholder-transparent text-start"
          ></textarea>
          <label
            for="field-message"
            class="pointer-events-none absolute inset-inline-start-0 top-3 font-body text-base text-brand-muted transition-all duration-300 start-3
              peer-focus:-top-4 peer-focus:text-xs peer-focus:text-brand-accent
              peer-[:not(:placeholder-shown)]:-top-4 peer-[:not(:placeholder-shown)]:text-xs"
          >
            {t(cs.fields.message)}
          </label>
        </div>

        <div class="flex flex-wrap items-center gap-5 pt-4">
          <button
            type="submit"
            data-magnetic
            class="interactive-card magnetic inline-flex items-center gap-3 rounded-full bg-brand-accent px-8 py-3.5 text-sm font-medium text-brand-bg transition-colors duration-300 hover:bg-brand-accent-hover"
          >
            {t(cs.submit)}
            <span aria-hidden="true">{forwardArrow}</span>
          </button>

          <a
            href={whatsappHref}
            target="_blank"
            rel="noopener noreferrer"
            data-magnetic
            class="interactive-card magnetic inline-flex items-center rounded-full border border-brand-accent/30 px-8 py-3.5 text-sm text-brand-text transition-colors duration-300 hover:border-brand-accent"
          >
            {t(c.whatsappDisplay)}
          </a>

          <p
            data-form-status
            class="ms-auto font-body text-sm text-brand-muted transition-opacity duration-300 opacity-0"
            role="status"
          ></p>
        </div>
      </div>
    </form>
  </div>
</section>

<script>
  // ---------------------------------------------------------------
  // Floating-label fallback for browsers without :placeholder-shown
  // support + a no-backend submission handler.
  // ---------------------------------------------------------------
  const successMessage = document.documentElement.getAttribute('dir') === 'rtl'
    ? 'تم استلام طلبك. سنتواصل معك قريباً.'
    : 'We received your request. We’ll be in touch shortly.';

  const initForm = () => {
    const gsap = (window as any).gsap;
    const form = document.querySelector<HTMLFormElement>('[data-contact-form]');
    const status = document.querySelector<HTMLElement>('[data-form-status]');
    if (!form || !status) return;

    form.querySelectorAll<HTMLInputElement>('input, textarea').forEach((el) => {
      const sync = () => el.classList.toggle('is-filled', !!el.value);
      sync();
      el.addEventListener('input', sync);
      el.addEventListener('blur', sync);
    });

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const payload = Object.fromEntries(data.entries());
      // Static site — log + surface a confirmation. Wire to a real endpoint
      // (e.g. Formspree / your CRM) here when ready.
      // eslint-disable-next-line no-console
      console.info('Naseem contact submission:', payload);

      status.textContent = successMessage;
      if (gsap) gsap.to(status, { opacity: 1, duration: 0.4 });
      form.reset();
      form.querySelectorAll('input, textarea').forEach((el) => el.classList.remove('is-filled'));

      window.setTimeout(() => {
        if (gsap) gsap.to(status, { opacity: 0, duration: 0.4, onComplete: () => (status.textContent = '') });
        else status.textContent = '';
      }, 4500);
    });

    // Magnetic submit + WhatsApp buttons (desktop only).
    const mm = gsap?.matchMedia?.();
    if (!mm) return;
    mm.add('(min-width: 1024px) and (pointer: fine)', () => {
      const magnetics = form.querySelectorAll<HTMLElement>('.magnetic');
      const handlers: Array<() => void> = [];
      magnetics.forEach((el) => {
        const strength = 0.35;
        const onMove = (e: MouseEvent) => {
          const r = el.getBoundingClientRect();
          const x = (e.clientX - (r.left + r.width / 2)) * strength;
          const y = (e.clientY - (r.top + r.height / 2)) * strength;
          gsap.to(el, { x, y, duration: 0.4, ease: 'power3.out' });
        };
        const onLeave = () => gsap.to(el, { x: 0, y: 0, duration: 0.5, ease: 'elastic.out(1, 0.3)' });
        el.addEventListener('mousemove', onMove);
        el.addEventListener('mouseleave', onLeave);
        handlers.push(() => {
          el.removeEventListener('mousemove', onMove);
          el.removeEventListener('mouseleave', onLeave);
        });
      });
      return () => handlers.forEach((fn) => fn());
    });
  };

  if ((window as any).gsapLoaded) initForm();
  else window.addEventListener('gsap:ready', initForm, { once: true });
</script>