---
/**
 * index.astro — the single landing page.
 * Components are composed in narrative order; nothing here is hardcoded —
 * each component pulls its data from src/data.
 */
import Layout from '../layouts/Layout.astro';
import CustomCursor from '../components/CustomCursor.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import AboutPhilosophy from '../components/AboutPhilosophy.astro';
import InteractiveTimeline from '../components/InteractiveTimeline.astro';
import HorizontalProjects from '../components/HorizontalProjects.astro';
import Partners from '../components/Partners.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <CustomCursor />
  <Navbar />
  <main>
    <Hero />
    <AboutPhilosophy />
    <InteractiveTimeline />
    <HorizontalProjects />
    <Partners />
    <ContactForm />
  </main>
  <Footer />
</Layout>